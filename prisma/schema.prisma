model VendorQuotationItem {
  id             String          @id @default(uuid())
  quotationId    String
  quotation      VendorQuotation @relation(fields: [quotationId], references: [id])
  rfqItemId      String?
  companyId      String
  itemCode       String
  itemName       String
  uom            String
  requiredQty    Float
  quotedQty      Float
  unitPrice      Float
  discount       Float?          @default(0)
  taxRate        Float?          @default(0)
  totalPrice     Float
  deliveryDays   Int?
  notes          String?
  isActive       Boolean         @default(true)
  isTestData     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String?
  updatedBy      String?

  @@map("vendor_quotation_items")
}

// MODULE 26 — QUOTATION COMPARISON
// ============================================================
model QuotationComparison {
  id                   String   @id @default(uuid())
