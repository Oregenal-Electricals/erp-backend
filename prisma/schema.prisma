  status      String   @default("INVITED") // INVITED, QUOTED, DECLINED
  isActive    Boolean  @default(true)
  isTestData  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  @@unique([rfqId, vendorId])
  @@map("rfq_vendors")
}

model RfqItem {
  id          String   @id @default(uuid())
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id])
  prItemId    String?
  companyId   String
  itemCode    String
  itemName    String
  uom         String
  requiredQty Float
  notes       String?
  isActive    Boolean  @default(true)
  isTestData  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  comparisons     QuotationComparison[]

  @@map("rfq_items")
}

// MODULE 25 — VENDOR QUOTATION
// ============================================================
model VendorQuotation {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  quotationNumber  String
