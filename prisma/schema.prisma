  isTestData       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?
  updatedBy        String?

  items            VendorQuotationItem[]

  comparisons     QuotationComparison[]

