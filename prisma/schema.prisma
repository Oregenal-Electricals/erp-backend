generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CORPORATE_ADMIN
  PLANT_HEAD
  UNIT_HEAD
  PRODUCTION_HEAD
  PLANNING_MANAGER
  PURCHASE_MANAGER
  STORE_MANAGER
  QC_MANAGER
  FINANCE_MANAGER
  HR_MANAGER
  SUPERVISOR
  OPERATOR
  VIEWER
}

enum FinancialYearStatus {
  OPEN
  CURRENT
  CLOSED
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum ChangeRequestType {
  MASTER_DATA
  USER_ACCESS
  PRICE_CHANGE
  CONFIG_CHANGE
  OTHER
}

model AuditLog {
  id         String   @id @default(uuid())
  tableName  String
  recordId   String
  action     String
  oldValues  Json?
  newValues  Json?
  changedBy  String
  changedAt  DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  reason     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("audit_logs")
  @@index([tableName, recordId])
  @@index([changedBy])
  @@index([changedAt])
}

model SystemHealth {
  id        String   @id @default(uuid())
  service   String
  status    String
  message   String?
  checkedAt DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("system_health")
}

model Company {
  id              String  @id @default(uuid())
  code            String  @unique
  name            String
  legalName       String
  pan             String?
  tan             String?
  cin             String?
  gstin           String?
  msmeNumber      String?
  address         String
  city            String
  state           String
  country         String  @default("India")
  pincode         String
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  currencyCode    String  @default("INR")
  fiscalYearStart Int     @default(4)
  timezone        String  @default("Asia/Kolkata")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  plants          Plant[]
  branches        Branch[]
  departments     Department[]
  financialYears  FinancialYear[]
  users           User[]
  numberingSeries NumberingSeries[]
  changeRequests  ChangeRequest[]

  @@map("companies")
  @@index([code])
  @@index([isActive])
}

model Plant {
  id        String  @id @default(uuid())
  code      String  @unique
  name      String
  gstin     String?
  address   String
  city      String
  state     String
  country   String  @default("India")
  pincode   String
  phone     String?
  email     String?
  plantType String  @default("MANUFACTURING")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  units Unit[]

  @@map("plants")
  @@index([companyId])
  @@index([code])
  @@index([isActive])
}

model Unit {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  unitType    String  @default("PRODUCTION")

  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("units")
  @@index([plantId])
  @@index([code])
  @@index([isActive])
}

model Department {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  headName    String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("departments")
  @@index([companyId])
  @@index([code])
  @@index([isActive])
}

model Branch {
  id         String  @id @default(uuid())
  code       String  @unique
  name       String
  gstin      String?
  address    String
  city       String
  state      String
  country    String  @default("India")
  pincode    String
  phone      String?
  email      String?
  branchType String  @default("SALES")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("branches")
  @@index([companyId])
  @@index([code])
  @@index([isActive])
}

model FinancialYear {
  id        String              @id @default(uuid())
  code      String              @unique
  label     String
  startDate DateTime
  endDate   DateTime
  status    FinancialYearStatus @default(OPEN)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("financial_years")
  @@unique([companyId, label])
  @@index([companyId])
  @@index([status])
}

model User {
  id            String   @id @default(uuid())
  employeeCode  String?  @unique
  firstName     String
  lastName      String
  email         String   @unique
  phone         String?
  passwordHash  String
  role          UserRole @default(VIEWER)
  mustChangePwd Boolean  @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  lastLoginAt   DateTime?
  isLocked      Boolean   @default(false)
  loginAttempts Int       @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  requestsMade     ChangeRequest[]        @relation("RequestedBy")
  requestsReviewed ChangeRequest[]        @relation("ReviewedBy")
  comments         ChangeRequestComment[]

  @@map("users")
  @@index([email])
  @@index([companyId])
  @@index([role])
}

model SystemSetting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String
  description String?
  category    String  @default("GENERAL")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("system_settings")
  @@index([category])
  @@index([key])
}

model NumberingSeries {
  id            String  @id @default(uuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])

  documentType  String
  prefix        String
  separator     String  @default("-")
  includeYear   Boolean @default(true)
  yearFormat    String  @default("YY-YY")
  padding       Int     @default(4)
  currentNumber Int     @default(0)
  lastGenerated String?
  isLocked      Boolean @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("numbering_series")
  @@unique([companyId, documentType])
  @@index([companyId])
  @@index([documentType])
}

model ChangeRequest {
  id            String              @id @default(uuid())
  requestNumber String              @unique
  title         String
  description   String
  type          ChangeRequestType   @default(OTHER)
  status        ChangeRequestStatus @default(DRAFT)
  priority      String              @default("NORMAL")

  companyId     String
  company       Company @relation(fields: [companyId], references: [id])

  requestedById String
  requestedBy   User   @relation("RequestedBy", fields: [requestedById], references: [id])

  reviewedById  String?
  reviewedBy    User?  @relation("ReviewedBy", fields: [reviewedById], references: [id])

  reviewedAt    DateTime?
  reviewComment String?
  submittedAt   DateTime?
  dueDate       DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  comments ChangeRequestComment[]

  @@map("change_requests")
  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([requestedById])
  @@index([requestNumber])
}

model ChangeRequestComment {
  id              String        @id @default(uuid())
  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id])

  comment   String
  commentBy String
  commenter User   @relation(fields: [commentBy], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("change_request_comments")
  @@index([changeRequestId])
}
