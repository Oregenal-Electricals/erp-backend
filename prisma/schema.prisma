  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id])
  prItemId         String?
  quotationItemId  String?
  companyId        String
  sequence         Int           @default(1)
  itemCode         String
  itemName         String
  hsnCode          String?
  uom              String
  orderedQty       Float
  receivedQty      Float         @default(0)
  pendingQty       Float
  unitPrice        Float
  discount         Float?        @default(0)
  taxRate          Float         @default(0)
  igstRate         Float         @default(0)
  cgstRate         Float         @default(0)
  sgstRate         Float         @default(0)
  taxAmount        Float         @default(0)
  totalPrice       Float
  status           String        @default("PENDING") // PENDING, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  isActive         Boolean       @default(true)
  isTestData       Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdBy        String?
  updatedBy        String?

  @@map("purchase_order_items")
}

// MODULE 28 — PO APPROVAL
// ============================================================
model PoApproval {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id])
  approvalLevel Int
  approvedBy    String
  action        String   // APPROVED, REJECTED
  remarks       String?
  isActive      Boolean  @default(true)
  isTestData    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  updatedBy     String?

  @@map("po_approvals")
}

model PoApprovalSetting {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  level       Int
  levelName   String
  minAmount   Float    @default(0)
  maxAmount   Float?
  isActive    Boolean  @default(true)
  isTestData  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  @@unique([companyId, level])
  @@map("po_approval_settings")
}

// MODULE 29 — PO AMENDMENT
// ============================================================
model PoAmendment {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  poId            String
  po              PurchaseOrder @relation(fields: [poId], references: [id])
  amendmentNumber String
  amendmentType   String        @default("GENERAL") // QUANTITY_CHANGE, DATE_CHANGE, ITEM_ADDITION, ITEM_CANCELLATION, PRICE_CORRECTION, GENERAL
  reason          String
  requestedBy     String
  status          String        @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  changes         Json?
  isActive        Boolean       @default(true)
  isTestData      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?

  @@unique([companyId, amendmentNumber])
  @@map("po_amendments")
}

// MODULE 31 — IMPORT PURCHASE ORDER
// ============================================================
model ImportPurchaseOrder {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  ipoNumber         String
  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id])
  prId              String?
  pr                PurchaseRequisition? @relation(fields: [prId], references: [id])
  poDate            DateTime  @default(now())
  deliveryDate      DateTime
  currency          String    @default("USD")
  exchangeRate      Float     @default(1)
  incoterms         String    @default("FOB") // FOB, CIF, EXW, CFR, DDP
  portOfLoading     String?
  portOfDischarge   String?
  paymentTerms      String?
  paymentMode       String    @default("LC") // LC, TT, DP, DA
  subtotalForeign   Float     @default(0)
  subtotalInr       Float     @default(0)
  totalTax          Float     @default(0)
  totalAmount       Float     @default(0)
  status            String    @default("DRAFT") // DRAFT, APPROVED, SENT, PROFORMA_RECEIVED, LC_OPENED, SHIPPED, CUSTOMS_CLEARED, CLOSED, CANCELLED
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  termsConditions   String?
  isActive          Boolean   @default(true)
  isTestData        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?

  items             ImportPoItem[]
  proformaInvoices  ProformaInvoice[]
  paymentInstruments PaymentInstrument[]
  shipments         Shipment[]
  shippingDocuments ShippingDocument[]

  @@unique([companyId, ipoNumber])
  @@map("import_purchase_orders")
}

model ImportPoItem {
  id              String              @id @default(uuid())
  ipoId           String
  ipo             ImportPurchaseOrder @relation(fields: [ipoId], references: [id])
  companyId       String
  sequence        Int                 @default(1)
  itemCode        String
  itemName        String
  hsnCode         String?
  uom             String
  orderedQty      Float
  receivedQty     Float               @default(0)
  pendingQty      Float
  unitPriceForeign Float
  unitPriceInr    Float
  discount        Float?              @default(0)
  taxRate         Float               @default(0)
  igstRate        Float               @default(0)
  bcdRate         Float               @default(0)
  taxAmount       Float               @default(0)
  totalForeign    Float
  totalInr        Float
  status          String              @default("PENDING")
  isActive        Boolean             @default(true)
  isTestData      Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       String?
  updatedBy       String?

  @@map("import_po_items")
}

// MODULE 32 — PROFORMA INVOICE
// ============================================================
model ProformaInvoice {
  id               String              @id @default(uuid())
  companyId        String
  company          Company             @relation(fields: [companyId], references: [id])
  ipoId            String
  ipo              ImportPurchaseOrder @relation(fields: [ipoId], references: [id])
  piNumber         String
  vendorPiNumber   String?
  piDate           DateTime            @default(now())
  currency         String              @default("USD")
  exchangeRate     Float               @default(1)
  subtotalForeign  Float               @default(0)
  totalAmount      Float               @default(0)
  validUntil       DateTime?
  bankName         String?
  bankAddress      String?
  swiftCode        String?
  status           String              @default("DRAFT") // DRAFT, RECEIVED, ACCEPTED, REJECTED
  rejectionReason  String?
  notes            String?
  isActive         Boolean             @default(true)
  isTestData       Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  createdBy        String?
  updatedBy        String?

  items            ProformaInvoiceItem[]

  paymentInstruments PaymentInstrument[]
  @@unique([companyId, piNumber])
  @@map("proforma_invoices")
}

model ProformaInvoiceItem {
  id               String          @id @default(uuid())
  piId             String
  pi               ProformaInvoice @relation(fields: [piId], references: [id])
  ipoItemId        String?
  companyId        String
  sequence         Int             @default(1)
  itemCode         String
  itemName         String
  hsnCode          String?
  uom              String
  qty              Float
  unitPriceForeign Float
  totalForeign     Float
  totalInr         Float
  isActive         Boolean         @default(true)
  isTestData       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        String?
  updatedBy        String?

  @@map("proforma_invoice_items")
}

// MODULE 33 — LC / TT MANAGEMENT
// ============================================================
model PaymentInstrument {
  id                   String              @id @default(uuid())
  companyId            String
  company              Company             @relation(fields: [companyId], references: [id])
  ipoId                String
  ipo                  ImportPurchaseOrder @relation(fields: [ipoId], references: [id])
  piId                 String?
  pi                   ProformaInvoice?    @relation(fields: [piId], references: [id])
  instrumentNumber     String
  instrumentType       String              @default("LC") // LC, TT, DP, DA
  bankName             String
  bankReference        String?
  vendorBankName       String?
  vendorSwiftCode      String?
  currency             String              @default("USD")
  amount               Float
  amountInr            Float
  issueDate            DateTime            @default(now())
  expiryDate           DateTime?
  latestShipmentDate   DateTime?
  presentationDays     Int?
  status               String              @default("DRAFT") // DRAFT, OPENED, AMENDED, EXPIRED, SETTLED, CANCELLED
  notes                String?
  isActive             Boolean             @default(true)
  isTestData           Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdBy            String?
  updatedBy            String?

  @@unique([companyId, instrumentNumber])
  @@map("payment_instruments")
}

// MODULE 34 — SHIPMENT TRACKING
// ============================================================
model Shipment {
  id                    String              @id @default(uuid())
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id])
  ipoId                 String
  ipo                   ImportPurchaseOrder @relation(fields: [ipoId], references: [id])
  paymentInstrumentId   String?
  shipmentNumber        String
  shipmentMode          String              @default("SEA") // SEA, AIR, ROAD, COURIER
  carrierName           String
  vesselName            String?
  voyageNumber          String?
  flightNumber          String?
  blNumber              String?
  awbNumber             String?
  portOfLoading         String?
  portOfDischarge       String?
  etd                   DateTime?
  eta                   DateTime?
  atd                   DateTime?
  ata                   DateTime?
  totalPackages         Int?
  totalWeight           Float?
  totalVolume           Float?
  status                String              @default("BOOKED") // BOOKED, DEPARTED, IN_TRANSIT, ARRIVED, DELIVERED, CANCELLED
  notes                 String?
  isActive              Boolean             @default(true)
  isTestData            Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  createdBy             String?
  updatedBy             String?

  containers            ShipmentContainer[]

  shippingDocuments ShippingDocument[]
  @@unique([companyId, shipmentNumber])
  @@map("shipments")
}

model ShipmentContainer {
  id              String   @id @default(uuid())
  shipmentId      String
  shipment        Shipment @relation(fields: [shipmentId], references: [id])
  companyId       String
  containerNumber String
  containerType   String   @default("20GP") // 20GP, 40GP, 40HC, 20RF, 40RF
  sealNumber      String?
  isActive        Boolean  @default(true)
  isTestData      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?

  @@map("shipment_containers")
}

// MODULE 35 — BL / AWB MANAGEMENT
// ============================================================
model ShippingDocument {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  shipmentId          String
  shipment            Shipment @relation(fields: [shipmentId], references: [id])
  ipoId               String
  ipo                 ImportPurchaseOrder @relation(fields: [ipoId], references: [id])
  documentType        String   @default("BL") // BL, AWB, SEAWAY_BILL
  documentNumber      String
  issueDate           DateTime?
  placeOfIssue        String?
  shipperName         String?
  consigneeName       String?
  notifyParty         String?
  portOfLoading       String?
  portOfDischarge     String?
  descriptionOfGoods  String?
  freightTerms        String?  @default("PREPAID") // PREPAID, COLLECT
  numberOfOriginals   Int?
  originalsReceived   Int?
  status              String   @default("RECEIVED") // DRAFT, RECEIVED, VERIFIED, SURRENDERED
  notes               String?
  isActive            Boolean  @default(true)
  isTestData          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  @@unique([companyId, documentNumber])
  @@map("shipping_documents")
}
