  financialYear     String    // "2025-26"
  section80C        Float     @default(0)
  section80D        Float     @default(0)
  section80G        Float     @default(0)
  section80E        Float     @default(0)
  otherDeductions   Float     @default(0)
  rentPaid          Float     @default(0)
  isMetroCity       Boolean   @default(false)
  hraExemption      Float     @default(0)
  standardDeduction Float     @default(50000)
  taxableIncome     Float     @default(0)
  annualTax         Float     @default(0)
  monthlyTds        Float     @default(0)
  regime            String    @default("NEW") // OLD, NEW
  remarks           String?
  isActive          Boolean   @default(true)
  isTestData        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?

  @@unique([companyId, employeeId, financialYear])
  @@index([companyId, financialYear])
  @@map("tds_declarations")
}
