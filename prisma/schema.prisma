// PHASE 7 — PRODUCTION PLANNING & MES
// MODULE 54 — WORK ORDER MANAGEMENT
// ============================================================
model WorkOrder {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  woNumber          String
  productCode       String
  productName       String
  uom               String    @default("PCS")
  bomId             String?
  bom               Bom?      @relation(fields: [bomId], references: [id])
  warehouseId       String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id])
  plannedQty        Float     @default(0)
  completedQty      Float     @default(0)
  rejectedQty       Float     @default(0)
  plannedStartDate  DateTime
  plannedEndDate    DateTime
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  status            String    @default("DRAFT") // DRAFT, RELEASED, IN_PROGRESS, COMPLETED, CANCELLED
  priority          String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  remarks           String?
  isActive          Boolean   @default(true)
  isTestData        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?

  productionIssues ProductionIssue[]
  productionEntries ProductionEntry[]
  productionQcs ProductionQc[]
  fgReceipts FgReceipt[]
  costSheet ProductionCostSheet?
  ncrRecords NcrRecord[]
  oqcInspections OqcInspection[]
  @@unique([companyId, woNumber])
  @@index([companyId, status])
  @@map("work_orders")
