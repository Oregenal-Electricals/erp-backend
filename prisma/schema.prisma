  selectionReason      String?
  isActive             Boolean  @default(true)
  isTestData           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdBy            String?
  updatedBy            String?

  @@unique([companyId, rfqId, rfqItemId])
  @@map("quotation_comparisons")
}

// MODULE 27 — PURCHASE ORDER
// ============================================================
model PurchaseOrder {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  poNumber         String
  rfqId            String?
  rfq              Rfq?      @relation(fields: [rfqId], references: [id])
  vendorId         String
  vendor           Vendor    @relation(fields: [vendorId], references: [id])
  prId             String?
  pr               PurchaseRequisition? @relation(fields: [prId], references: [id])
  poDate           DateTime  @default(now())
  deliveryDate     DateTime
  deliveryAddress  String?
  paymentTerms     String?
  currency         String    @default("INR")
  subtotal         Float     @default(0)
  totalTax         Float     @default(0)
  totalAmount      Float     @default(0)
  status           String    @default("DRAFT") // DRAFT, APPROVED, SENT, PARTIALLY_RECEIVED, CLOSED, CANCELLED
  approvedBy       String?
  approvedAt       DateTime?
