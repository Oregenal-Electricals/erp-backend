// MODULE 20 — PRODUCT REVISION CONTROL
// ============================================================
model ProductRevision {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
