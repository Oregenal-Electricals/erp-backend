generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CORPORATE_ADMIN
  PLANT_HEAD
  UNIT_HEAD
  PRODUCTION_HEAD
  PLANNING_MANAGER
  PURCHASE_MANAGER
  STORE_MANAGER
  QC_MANAGER
  FINANCE_MANAGER
  HR_MANAGER
  SUPERVISOR
  OPERATOR
  VIEWER
}

enum FinancialYearStatus {
  OPEN
  CURRENT
  CLOSED
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum ChangeRequestType {
  MASTER_DATA
  USER_ACCESS
  PRICE_CHANGE
  CONFIG_CHANGE
  OTHER
}

enum VisitorStatus {
  PENDING
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum IdProofType {
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  EMPLOYEE_ID
  OTHER
}

enum VehicleType {
  TRUCK
  TEMPO
  CAR
  TWO_WHEELER
  CONTAINER
  TANKER
  OTHER
}

enum VehicleLogStatus {
  INSIDE
  EXITED
  CANCELLED
}

enum VehiclePurpose {
  INWARD
  OUTWARD
  INTERNAL
  SERVICE
  OTHER
}

enum GateInwardStatus {
  PENDING
  VERIFIED
  SENT_TO_STORES
  COMPLETED
  REJECTED
}

enum GateOutwardStatus {
  PENDING
  APPROVED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum GatePassType {
  RETURNABLE
  NON_RETURNABLE
  STAFF_EXIT
}

enum GatePassStatus {
  PENDING
  APPROVED
  ISSUED
  RETURNED
  EXPIRED
  CLOSED
  CANCELLED
}

enum ItemType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
  CONSUMABLE
  PACKAGING
  SPARE_PART
  TOOL
  SERVICE
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
  UNDER_DEVELOPMENT
}

model AuditLog {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  action    String
  oldValues Json?
  newValues Json?
  changedBy String
  changedAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  reason    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("audit_logs")
  @@index([tableName, recordId])
  @@index([changedBy])
  @@index([changedAt])
}

model SystemHealth {
  id        String   @id @default(uuid())
  service   String
  status    String
  message   String?
  checkedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("system_health")
}

model Company {
  id              String  @id @default(uuid())
  code            String  @unique
  name            String
  legalName       String
  pan             String?
  tan             String?
  cin             String?
  gstin           String?
  msmeNumber      String?
  address         String
  city            String
  state           String
  country         String  @default("India")
  pincode         String
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  currencyCode    String  @default("INR")
  fiscalYearStart Int     @default(4)
  timezone        String  @default("Asia/Kolkata")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  plants             Plant[]
  branches           Branch[]
  departments        Department[]
  financialYears     FinancialYear[]
  users              User[]
  numberingSeries    NumberingSeries[]
  changeRequests     ChangeRequest[]
  visitors           Visitor[]
  visitorLogs        VisitorLog[]
  vehicles           Vehicle[]
  vehicleLogs        VehicleLog[]
  gateInwardEntries  GateInwardEntry[]
  gateOutwardEntries GateOutwardEntry[]
  gatePasses         GatePass[]
  unitOfMeasures     UnitOfMeasure[]
  itemCategories     ItemCategory[]
  items              Item[]
  warehouses         Warehouse[]
  vendors            Vendor[]
  products           Product[]
  rawMaterials       RawMaterial[]
  hsnSacCodes        HsnSacCode[]
  priceLists         PriceList[]
  productRevisions    ProductRevision[]
  boms               Bom[]
  bomRevisions       BomRevision[]
  customFieldDefinitions CustomFieldDefinition[]
  purchaseRequisitions PurchaseRequisition[]
  rfqs                 Rfq[]
  vendorQuotations     VendorQuotation[]
  quotationComparisons QuotationComparison[]
  purchaseOrders      PurchaseOrder[]
  poApprovals         PoApproval[]
  poApprovalSettings  PoApprovalSetting[]
  poAmendments        PoAmendment[]
  importPurchaseOrders ImportPurchaseOrder[]
  proformaInvoices    ProformaInvoice[]
  paymentInstruments  PaymentInstrument[]
  shipments           Shipment[]
  shippingDocuments   ShippingDocument[]
  customsEntries     CustomsEntry[]
  landedCosts        LandedCost[]
  grnHeaders         GrnHeader[]
  iqcInspections     IqcInspection[]
  stockLedgers       StockLedger[]
  stockBalances      StockBalance[]
  rejectedStocks     RejectedStock[]
  stockPutaways      StockPutaway[]
  stockBatches       StockBatch[]
  stockIssues        StockIssue[]
  stockTransfers     StockTransfer[]
  stockAdjustments   StockAdjustment[]
  workOrders         WorkOrder[]
  productionIssues   ProductionIssue[]
  productionEntries  ProductionEntry[]
  productionQcs      ProductionQc[]
  fgReceipts         FgReceipt[]
  costSheets         ProductionCostSheet[]
  ncrRecords         NcrRecord[]
  capaRecords        CapaRecord[]
  rcaRecords         RcaRecord[]
  oqcInspections     OqcInspection[]
  supplierQualityRatings SupplierQualityRating[]
  customerComplaints CustomerComplaint[]
  leads              Lead[]
  quotations         Quotation[]
  customerPos        CustomerPo[]
  salesOrders        SalesOrder[]
  dispatchPlans      DispatchPlan[]
  dispatches         Dispatch[]
  deliveryConfirmations DeliveryConfirmation[]
  accounts           Account[]
  vouchers           Voucher[]
  arInvoices         ArInvoice[]
  arPayments         ArPayment[]
  apBills            ApBill[]
  apPayments         ApPayment[]
  gstReturns         GstReturn[]
  bankStatements     BankStatement[]
  customerCreditLimits CustomerCreditLimit[]
  creditHolds        CreditHold[]
  notifications      Notification[]
  alertTemplates     AlertTemplate[]
  alertLogs          AlertLog[]
  workflowDefinitions WorkflowDefinition[]
  approvalRequests   ApprovalRequest[]
  tasks              Task[]
  documents          Document[]
  hrDepartments      HrDepartment[]
  hrDesignations     HrDesignation[]
  employees          Employee[]
  shifts             Shift[]
  attendance         Attendance[]
  leaveTypes         LeaveType[]
  leaveBalances      LeaveBalance[]
  leaveApplications  LeaveApplication[]
  payrollRuns        PayrollRun[]
  payrollEntries     PayrollEntry[]
  tdsDeclarations    TdsDeclaration[]
  supplierCars       SupplierCar[]
  warehouseZones     WarehouseZone[]
  warehouseRacks     WarehouseRack[]
  warehouseBins      WarehouseBin[]
  customFieldValues      CustomFieldValue[]

  @@map("companies")
  @@index([code])
  @@index([isActive])
}

model Plant {
  id        String  @id @default(uuid())
  code      String  @unique
  name      String
  gstin     String?
  address   String
  city      String
  state     String
  country   String  @default("India")
  pincode   String
  phone     String?
  email     String?
  plantType String  @default("MANUFACTURING")
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  units              Unit[]
  visitorLogs        VisitorLog[]
  vehicleLogs        VehicleLog[]       @relation("VehiclePlant")
  gateInwardEntries  GateInwardEntry[]  @relation("GateInwardPlant")
  gateOutwardEntries GateOutwardEntry[] @relation("GateOutwardPlant")
  gatePasses         GatePass[]         @relation("GatePassPlant")
  warehouses         Warehouse[]        @relation("WarehousePlant")

  @@map("plants")
  @@index([companyId])
  @@index([code])
  @@index([isActive])
}

model Unit {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  unitType    String  @default("PRODUCTION")
  plantId     String
  plant       Plant   @relation(fields: [plantId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("units")
  @@index([plantId])
  @@index([code])
  @@index([isActive])
}

model Department {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  headName    String?
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("departments")
  @@index([companyId])
  @@index([code])
  @@index([isActive])
}

model Branch {
  id         String  @id @default(uuid())
  code       String  @unique
  name       String
  gstin      String?
  address    String
  city       String
  state      String
  country    String  @default("India")
  pincode    String
  phone      String?
  email      String?
  branchType String  @default("SALES")
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("branches")
  @@index([companyId])
  @@index([code])
  @@index([isActive])
}

model FinancialYear {
  id        String              @id @default(uuid())
  code      String              @unique
  label     String
  startDate DateTime
  endDate   DateTime
  status    FinancialYearStatus @default(OPEN)
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("financial_years")
  @@unique([companyId, label])
  @@index([companyId])
  @@index([status])
}

model User {
  id            String   @id @default(uuid())
  employeeCode  String?  @unique
  firstName     String
  lastName      String
  email         String   @unique
  phone         String?
  passwordHash  String
  role          UserRole @default(VIEWER)
  additionalRoles UserRole[]
  mustChangePwd Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  lastLoginAt   DateTime?
  isLocked      Boolean   @default(false)
  loginAttempts Int       @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  requestsMade     ChangeRequest[]    @relation("RequestedBy")
  requestsReviewed ChangeRequest[]    @relation("ReviewedBy")
  comments         ChangeRequestComment[]
  hostVisits       VisitorLog[]       @relation("HostEmployee")
  checkedInVisits  VisitorLog[]       @relation("CheckedInBy")
  checkedOutVisits VisitorLog[]       @relation("CheckedOutBy")
  vehicleEntries   VehicleLog[]       @relation("VehicleEntryBy")
  vehicleExits     VehicleLog[]       @relation("VehicleExitBy")
  ginReceived      GateInwardEntry[]  @relation("GINReceivedBy")
  ginVerified      GateInwardEntry[]  @relation("GINVerifiedBy")
  goeAuthorized    GateOutwardEntry[] @relation("GOEAuthorizedBy")
  goeDispatched    GateOutwardEntry[] @relation("GOEDispatchedBy")
  goeCreated       GateOutwardEntry[] @relation("GOECreatedBy")
  gpRequested      GatePass[]         @relation("GPRequestedBy")
  gpAuthorized     GatePass[]         @relation("GPAuthorizedBy")
  gpIssued         GatePass[]         @relation("GPIssuedBy")
  gpClosed         GatePass[]         @relation("GPClosedBy")
  gpEmployee       GatePass[]         @relation("GPEmployee")

  @@map("users")
  @@index([email])
  @@index([companyId])
  @@index([role])
}

model SystemSetting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String
  description String?
  category    String  @default("GENERAL")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String   @default("system")
  updatedBy  String   @default("system")
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("system_settings")
  @@index([category])
  @@index([key])
}

model NumberingSeries {
  id            String  @id @default(uuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  documentType  String
  prefix        String
  separator     String  @default("-")
  includeYear   Boolean @default(true)
  yearFormat    String  @default("YY-YY")
  padding       Int     @default(4)
  currentNumber Int     @default(0)
  lastGenerated String?
  isLocked      Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("numbering_series")
  @@unique([companyId, documentType])
  @@index([companyId])
  @@index([documentType])
}

model ChangeRequest {
  id            String              @id @default(uuid())
  requestNumber String              @unique
  title         String
  description   String
  type          ChangeRequestType   @default(OTHER)
  status        ChangeRequestStatus @default(DRAFT)
  priority      String              @default("NORMAL")
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  requestedById String
  requestedBy   User   @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?  @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewComment String?
  submittedAt   DateTime?
  dueDate       DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  comments ChangeRequestComment[]

  @@map("change_requests")
  @@index([companyId])
  @@index([requestedById])
  @@index([requestNumber])
}

model ChangeRequestComment {
  id              String        @id @default(uuid())
  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id])
  comment   String
  commentBy String
  commenter User   @relation(fields: [commentBy], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("change_request_comments")
  @@index([changeRequestId])
}

model Visitor {
  id              String      @id @default(uuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  firstName       String
  lastName        String
  mobile          String
  email           String?
  visitorCompany  String?
  designation     String?
  idProofType     IdProofType @default(AADHAAR)
  idProofNumber   String
  photoUrl        String?
  isBlacklisted   Boolean     @default(false)
  blacklistReason String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  logs VisitorLog[]

  @@map("visitors")
  @@index([companyId])
  @@index([mobile])
  @@index([idProofNumber])
}

model VisitorLog {
  id             String        @id @default(uuid())
  logNumber      String        @unique
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  visitorId      String
  visitor        Visitor       @relation(fields: [visitorId], references: [id])
  plantId        String
  plant          Plant         @relation(fields: [plantId], references: [id])
  hostEmployeeId String?
  hostEmployee   User?         @relation("HostEmployee", fields: [hostEmployeeId], references: [id])
  checkedInById  String
  checkedInBy    User          @relation("CheckedInBy", fields: [checkedInById], references: [id])
  checkedOutById String?
  checkedOutBy   User?         @relation("CheckedOutBy", fields: [checkedOutById], references: [id])
  purpose        String
  vehicleNumber  String?
  itemsCarried   String?
  areasToVisit   String?
  remarks        String?
  checkInTime    DateTime      @default(now())
  checkOutTime   DateTime?
  expectedOutTime DateTime?
  status         VisitorStatus @default(CHECKED_IN)
  passNumber     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("visitor_logs")
  @@index([companyId])
  @@index([visitorId])
  @@index([plantId])
  @@index([checkInTime])
  @@index([logNumber])
}

model Vehicle {
  id               String      @id @default(uuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  vehicleNumber    String
  vehicleType      VehicleType @default(TRUCK)
  ownerName        String?
  ownerMobile      String?
  isCompanyVehicle Boolean     @default(false)
  remarks          String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  logs VehicleLog[]

  @@map("vehicles")
  @@unique([companyId, vehicleNumber])
  @@index([companyId])
  @@index([vehicleNumber])
}

model VehicleLog {
  id            String           @id @default(uuid())
  logNumber     String           @unique
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id])
  vehicleId     String
  vehicle       Vehicle          @relation(fields: [vehicleId], references: [id])
  plantId       String
  plant         Plant            @relation("VehiclePlant", fields: [plantId], references: [id])
  driverName    String
  driverMobile  String?
  driverLicense String?
  purpose       VehiclePurpose   @default(INWARD)
  status        VehicleLogStatus @default(INSIDE)
  inWeight      Float?
  outWeight     Float?
  netWeight     Float?
  materialDescription String?
  supplierName        String?
  customerName        String?
  poNumber            String?
  remarks             String?
  entryTime     DateTime         @default(now())
  exitTime      DateTime?
  expectedExitTime DateTime?
  entryById     String
  entryBy       User             @relation("VehicleEntryBy", fields: [entryById], references: [id])
  exitById      String?
  exitBy        User?            @relation("VehicleExitBy", fields: [exitById], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  gateInwardEntries  GateInwardEntry[]
  gateOutwardEntries GateOutwardEntry[] @relation("OutwardVehicleLog")

  @@map("vehicle_logs")
  @@index([companyId])
  @@index([vehicleId])
  @@index([plantId])
  @@index([entryTime])
  @@index([logNumber])
}

model GateInwardEntry {
  id           String           @id @default(uuid())
  ginNumber    String           @unique
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id])
  plantId      String
  plant        Plant            @relation("GateInwardPlant", fields: [plantId], references: [id])
  vehicleLogId String?
  vehicleLog   VehicleLog?      @relation(fields: [vehicleLogId], references: [id])
  supplierName    String
  supplierMobile  String?
  supplierGstin   String?
  poNumber        String?
  invoiceNumber   String?
  invoiceDate     DateTime?
  invoiceAmount   Float?
  materialDescription String
  quantity            Float
  unit                String   @default("NOS")
  grossWeight         Float?
  netWeight           Float?
  packageCount        Int?
  status          GateInwardStatus @default(PENDING)
  remarks         String?
  rejectionReason String?
  receivedById  String
  receivedBy    User             @relation("GINReceivedBy", fields: [receivedById], references: [id])
  verifiedById  String?
  verifiedBy    User?            @relation("GINVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?
  completedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("gate_inward_entries")
  @@index([companyId])
  @@index([plantId])
  @@index([ginNumber])
  @@index([poNumber])
  @@index([createdAt])
}

model GateOutwardEntry {
  id           String            @id @default(uuid())
  goeNumber    String            @unique
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  plantId      String
  plant        Plant             @relation("GateOutwardPlant", fields: [plantId], references: [id])
  vehicleLogId String?
  vehicleLog   VehicleLog?       @relation("OutwardVehicleLog", fields: [vehicleLogId], references: [id])
  customerName    String
  customerMobile  String?
  customerAddress String?
  customerGstin   String?
  salesOrderNumber      String?
  deliveryChallanNumber String?
  invoiceNumber         String?
  invoiceAmount         Float?
  materialDescription String
  quantity            Float
  unit                String   @default("NOS")
  grossWeight         Float?
  netWeight           Float?
  packageCount        Int?
  status        GateOutwardStatus @default(PENDING)
  remarks       String?
  cancelReason  String?
  authorizedById String?
  authorizedBy   User?    @relation("GOEAuthorizedBy", fields: [authorizedById], references: [id])
  authorizedAt   DateTime?
  dispatchedById String?
  dispatchedBy   User?    @relation("GOEDispatchedBy", fields: [dispatchedById], references: [id])
  dispatchedAt   DateTime?
  createdById    String
  createdByUser  User     @relation("GOECreatedBy", fields: [createdById], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("gate_outward_entries")
  @@index([companyId])
  @@index([plantId])
  @@index([goeNumber])
  @@index([createdAt])
}

model GatePass {
  id          String         @id @default(uuid())
  passNumber  String         @unique
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  plantId     String
  plant       Plant          @relation("GatePassPlant", fields: [plantId], references: [id])
  type        GatePassType   @default(NON_RETURNABLE)
  status      GatePassStatus @default(PENDING)
  purpose     String
  carrierName    String
  carrierMobile  String?
  carrierIdProof String?
  vehicleNumber  String?
  itemDescription String
  quantity        Float
  unit            String   @default("NOS")
  estimatedValue  Float?
  validFrom   DateTime?
  validTo     DateTime?
  returnedAt  DateTime?
  remarks     String?
  cancelReason String?
  employeeId          String?
  employee            User?     @relation("GPEmployee", fields: [employeeId], references: [id])
  exitType            String?
  expectedReturnTime  DateTime?
  actualReturnTime    DateTime?
  departmentName      String?
  requestedById  String
  requestedBy    User    @relation("GPRequestedBy", fields: [requestedById], references: [id])
  authorizedById String?
  authorizedBy   User?   @relation("GPAuthorizedBy", fields: [authorizedById], references: [id])
  authorizedAt   DateTime?
  issuedById    String?
  issuedBy      User?   @relation("GPIssuedBy", fields: [issuedById], references: [id])
  issuedAt      DateTime?
  closedById    String?
  closedBy      User?   @relation("GPClosedBy", fields: [closedById], references: [id])
  closedAt      DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("gate_passes")
  @@index([companyId])
  @@index([plantId])
  @@index([passNumber])
  @@index([createdAt])
}

// ============================================================
// MODULE 13 — ITEM MASTER (UOM + Category + Item)
// ============================================================

model UnitOfMeasure {
  id          String  @id @default(uuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  isBase      Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  items           Item[]
  products         Product[]
  rawMaterials     RawMaterial[] @relation("RawMaterialUom")
  purchaseUomItems Item[] @relation("PurchaseUom")
  salesUomItems    Item[] @relation("SalesUom")

  @@map("unit_of_measures")
  @@unique([companyId, code])
  @@index([companyId])
}

model ItemCategory {
  id          String  @id @default(uuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  parentId    String?
  parent      ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ItemCategory[] @relation("CategoryTree")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  items    Item[]
  products     Product[]
  rawMaterials RawMaterial[]

  @@map("item_categories")
  @@unique([companyId, code])
  @@index([companyId])
}

model Item {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  itemCode    String
  itemName    String
  shortName   String?
  description String?
  itemType    ItemType   @default(RAW_MATERIAL)
  status      ItemStatus @default(ACTIVE)
  categoryId  String?
  category    ItemCategory? @relation(fields: [categoryId], references: [id])
  uomId       String
  uom         UnitOfMeasure @relation(fields: [uomId], references: [id])
  purchaseUomId String?
  purchaseUom   UnitOfMeasure? @relation("PurchaseUom", fields: [purchaseUomId], references: [id])
  salesUomId  String?
  salesUom    UnitOfMeasure? @relation("SalesUom", fields: [salesUomId], references: [id])
  hsnCode     String?
  gstRate     Float   @default(18)
  sacCode     String?
  purchaseRate     Float?
  salesRate        Float?
  standardCost     Float?
  lastPurchaseRate Float?
  reorderLevel    Float?
  reorderQty      Float?
  minOrderQty     Float?
  maxOrderQty     Float?
  leadTimeDays    Int?
  shelfLifeDays   Int?
  isBatchTracked  Boolean @default(false)
  isSerialTracked Boolean @default(false)
  isMaintenance   Boolean @default(false)
  drawingNo       String?
  specifications  Json?
  imageUrl        String?
  barcode         String?
  abcClass        String?
  criticalityLevel String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("items")
  @@unique([companyId, itemCode])
  @@index([companyId])
  @@index([itemType])
  @@index([categoryId])
  @@index([hsnCode])
}


// ============================================================
// MODULE 14 — WAREHOUSE MANAGEMENT
// ============================================================

enum WarehouseType {
  RAW_MATERIAL
  FINISHED_GOOD
  WIP
  SPARE_PART
  SCRAP
  GENERAL
}

model Warehouse {
  id          String        @id @default(uuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  plantId     String
  plant       Plant         @relation("WarehousePlant", fields: [plantId], references: [id])
  code        String
  name        String
  type        WarehouseType @default(GENERAL)
  description String?
  address     String?
  capacity    Float?
  isDefault   Boolean       @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  zones Zone[]

  grnHeaders  GrnHeader[]
  stockLedgers StockLedger[]
  rejectedStocks  RejectedStock[]
  stockPutaways  StockPutaway[]
  stockBatches   StockBatch[]
  stockIssues    StockIssue[]
  stockAdjustments StockAdjustment[]
  workOrders     WorkOrder[]
  productionIssues ProductionIssue[]
  fgReceipts FgReceipt[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
  warehouseZones WarehouseZone[]
  warehouseRacks WarehouseRack[]
  warehouseBins  WarehouseBin[]
  stockBalances StockBalance[]
  @@map("warehouses")
  @@unique([companyId, code])
  @@index([companyId])
  @@index([plantId])
}

model Zone {
  id           String    @id @default(uuid())
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  code         String
  name         String
  description  String?
  temperature  String?   // AMBIENT, COLD, FROZEN
  isHazmat     Boolean   @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  racks Rack[]

  @@map("zones")
  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model Rack {
  id          String  @id @default(uuid())
  zoneId      String
  zone        Zone    @relation(fields: [zoneId], references: [id])
  code        String
  name        String
  description String?
  maxWeight   Float?
  maxVolume   Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  bins Bin[]

  @@map("racks")
  @@unique([zoneId, code])
  @@index([zoneId])
}

model Bin {
  id          String  @id @default(uuid())
  rackId      String
  rack        Rack    @relation(fields: [rackId], references: [id])
  code        String
  name        String
  binType     String  @default("STORAGE") // STORAGE, STAGING, QUARANTINE, REJECTION
  maxQty      Float?
  description String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String
  isActive   Boolean  @default(true)
  isTestData Boolean  @default(false)

  @@map("bins")
  @@unique([rackId, code])
  @@index([rackId])
}

model Vendor {
  id                String   @id @default(uuid())
  companyId         String
  code              String
  name              String
  legalName         String?
  vendorType        String   @default("SUPPLIER") // SUPPLIER, CONTRACTOR, SERVICE_PROVIDER, TRANSPORTER
  gstin             String?
  pan               String?
  msmeNumber        String?
  isMsme            Boolean  @default(false)
  email             String?
  phone             String?
  alternatePhone    String?
  website           String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  pincode           String?
  country           String   @default("India")
  billingAddress    String?
  shippingAddress   String?
  bankName          String?
  bankBranch        String?
  accountNumber     String?
  ifscCode          String?
  paymentTerms      String?  // NET_30, NET_60, IMMEDIATE, etc.
  creditLimit       Float?
  currency          String   @default("INR")
  tdsApplicable     Boolean  @default(false)
  tdsSection        String?
  rating            Int?     // 1-5
  notes             String?
  isActive          Boolean  @default(true)
  isTestData        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  updatedBy         String?

  company           Company  @relation(fields: [companyId], references: [id])

  rfqVendors      RfqVendor[]
  quotations      VendorQuotation[]
  comparisonSelections QuotationComparison[] @relation("ComparisonVendor")
  importPurchaseOrders ImportPurchaseOrder[]
  purchaseOrders  PurchaseOrder[]

  @@unique([companyId, code])
  qualityRatings SupplierQualityRating[]
  apBills        ApBill[] @relation("ApBillVendor")
  supplierCars   SupplierCar[] @relation("SupplierCarVendor")
  @@map("vendors")
}

// MODULE 15 — PRODUCT MASTER
// ============================================================
model Product {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  code            String
  name            String
  description     String?
  productType     String        @default("FINISHED_GOOD") // FINISHED_GOOD, SEMI_FINISHED, BY_PRODUCT
  categoryId      String?
  category        ItemCategory? @relation(fields: [categoryId], references: [id])
  uomId           String?
  uom             UnitOfMeasure? @relation(fields: [uomId], references: [id])
  hsnCode         String?
  gstRate         Float?
  brand           String?
  model           String?
  revision        String?
  drawingNumber   String?
  specifications  Json?
  minOrderQty     Float?
  leadTimeDays    Int?
  isActive        Boolean       @default(true)
  isTestData      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?

  revisions       ProductRevision[]
  boms            Bom[]
  bomRevisions    BomRevision[] @relation("BomRevisionProduct")

  @@unique([companyId, code])
  @@map("products")
}

// MODULE 16 — RAW MATERIAL MASTER
// ============================================================
model RawMaterial {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  code            String
  name            String
  description     String?
  materialType    String        @default("ELECTRONIC") // ELECTRONIC, MECHANICAL, ELECTRICAL, CHEMICAL, PACKAGING, OTHER
  categoryId      String?
  category        ItemCategory? @relation(fields: [categoryId], references: [id])
  uomId           String?
  uom             UnitOfMeasure? @relation("RawMaterialUom", fields: [uomId], references: [id])
  hsnCode         String?
  gstRate         Float?
  brand           String?
  partNumber      String?
  specifications  Json?
  minStockLevel   Float?
  maxStockLevel   Float?
  reorderQty      Float?
  leadTimeDays    Int?
  isActive        Boolean       @default(true)
  isTestData      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?

  bomItems        BomItem[]
  prItems         PurchaseRequisitionItem[]

  @@unique([companyId, code])
  @@map("raw_materials")
}

// MODULE 17 — HSN/SAC MASTER
// ============================================================
model HsnSacCode {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  code        String
  codeType    String   @default("HSN") // HSN, SAC
  description String
  gstRate     Float    @default(18)
  igstRate    Float    @default(18)
  cgstRate    Float    @default(9)
  sgstRate    Float    @default(9)
  cessRate    Float?
  isActive    Boolean  @default(true)
  isTestData  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  @@unique([companyId, code])
  @@map("hsn_sac_codes")
}

// MODULE 18 — PRICE LIST MANAGEMENT
// ============================================================
model PriceList {
  id          String          @id @default(uuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  listType    String          @default("SALES") // SALES, PURCHASE
  currency    String          @default("INR")
  isDefault   Boolean         @default(false)
  isActive    Boolean         @default(true)
  isTestData  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?
  updatedBy   String?

  items       PriceListItem[]

  @@unique([companyId, code])
  @@map("price_lists")
}

model PriceListItem {
  id          String    @id @default(uuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])
  companyId   String
  itemType    String    @default("PRODUCT") // PRODUCT, RAW_MATERIAL, ITEM
  itemId      String
  itemCode    String
  itemName    String
  uom         String?
  price       Float
  minQty      Float?
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  isApproved  Boolean   @default(false)
  isActive    Boolean   @default(true)
  isTestData  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?

  @@map("price_list_items")
}

// MODULE 20 — PRODUCT REVISION CONTROL
// ============================================================
model ProductRevision {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  revisionNumber    String
  changeDescription String
  changeType        String    @default("MINOR") // MAJOR, MINOR, PATCH
  previousRevision  String?
  drawingNumber     String?
  specifications    Json?
  effectiveDate     DateTime  @default(now())
  approvedBy        String?
  approvedAt        DateTime?
  status            String    @default("DRAFT") // DRAFT, APPROVED, OBSOLETE
  isActive          Boolean   @default(true)
  isTestData        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?

  boms            Bom[]

  @@unique([companyId, productId, revisionNumber])
  @@map("product_revisions")
}

// MODULE 21 — BOM MANAGEMENT
// ============================================================
model Bom {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  revisionId    String?
  revision      ProductRevision? @relation(fields: [revisionId], references: [id])
  bomNumber     String
  version       String    @default("v1")
  description   String?
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  status        String    @default("DRAFT") // DRAFT, APPROVED, OBSOLETE
  approvedBy    String?
  approvedAt    DateTime?
  totalCost     Float?
  isActive      Boolean   @default(true)
  isTestData    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?
  updatedBy     String?

  items         BomItem[]
  revisionsAsNew BomRevision[] @relation("BomRevisionNew")
  revisionsAsOld BomRevision[] @relation("BomRevisionOld")

  workOrders WorkOrder[]
  @@unique([companyId, bomNumber])
  @@map("boms")
}

model BomItem {
  id              String   @id @default(uuid())
  bomId           String
  bom             Bom      @relation(fields: [bomId], references: [id])
  companyId       String
  sequence        Int      @default(1)
  itemType        String   @default("RAW_MATERIAL") // RAW_MATERIAL, COMPONENT, SUB_ASSEMBLY
  rawMaterialId   String?
  rawMaterial     RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  itemCode        String
  itemName        String
  uom             String
  quantity        Float
  wastagePercent  Float?   @default(0)
  effectiveQty    Float
  unitCost        Float?
  totalCost       Float?
  isCritical      Boolean  @default(false)
  notes           String?
  isActive        Boolean  @default(true)
  isTestData      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?

  @@map("bom_items")
}

// MODULE 22 — BOM REVISION CONTROL
// ============================================================
model BomRevision {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  productId         String
  product           Product  @relation("BomRevisionProduct", fields: [productId], references: [id])
  bomId             String
  bom               Bom      @relation("BomRevisionNew", fields: [bomId], references: [id])
  previousBomId     String?
  previousBom       Bom?     @relation("BomRevisionOld", fields: [previousBomId], references: [id])
  revisionNumber    String
  changeType        String   @default("MINOR") // MAJOR, MINOR, PATCH
  changeDescription String
  ecnNumber         String?
  effectiveDate     DateTime @default(now())
  approvedBy        String?
  approvedAt        DateTime?
  status            String   @default("DRAFT") // DRAFT, APPROVED
  isActive          Boolean  @default(true)
  isTestData        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  updatedBy         String?

  @@unique([companyId, productId, revisionNumber])
  @@map("bom_revisions")
}

// MODULE 22A — CUSTOM FIELDS ENGINE
// ============================================================
model CustomFieldDefinition {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  module        String   // BOM, VENDOR, PRODUCT, RAW_MATERIAL, ITEM, PRICE_LIST
  fieldKey      String
  fieldLabel    String
  fieldType     String   @default("TEXT") // TEXT, NUMBER, DATE, BOOLEAN, DROPDOWN
  options       Json?
  placeholder   String?
  defaultValue  String?
  isRequired    Boolean  @default(false)
  isActive      Boolean  @default(true)
  isTestData    Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  updatedBy     String?

  @@unique([companyId, module, fieldKey])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  module      String
  recordId    String
  fieldKey    String
  value       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  @@unique([companyId, module, recordId, fieldKey])
  @@map("custom_field_values")
}

// PHASE 4 — PURCHASE MANAGEMENT
// MODULE 23 — PURCHASE REQUISITION
// ============================================================
model PurchaseRequisition {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  prNumber        String
  title           String
  description     String?
  requestedBy     String
  requestedDate   DateTime @default(now())
  requiredDate    DateTime
  department      String?
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status          String   @default("DRAFT")  // DRAFT, SUBMITTED, APPROVED, REJECTED, PO_RAISED, CLOSED
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  totalAmount     Float?
  notes           String?
  isActive        Boolean  @default(true)
  isTestData      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?

  items           PurchaseRequisitionItem[]
  rfqs            Rfq[]
  purchaseOrders  PurchaseOrder[]
  importPurchaseOrders ImportPurchaseOrder[]

  @@unique([companyId, prNumber])
  @@map("purchase_requisitions")
}

model PurchaseRequisitionItem {
  id               String              @id @default(uuid())
  prId             String
  pr               PurchaseRequisition @relation(fields: [prId], references: [id])
  companyId        String
  sequence         Int                 @default(1)
  itemType         String              @default("RAW_MATERIAL") // RAW_MATERIAL, ITEM, OTHER
  rawMaterialId    String?
  rawMaterial      RawMaterial?        @relation(fields: [rawMaterialId], references: [id])
  itemCode         String
  itemName         String
  description      String?
  uom              String
  requiredQty      Float
  approvedQty      Float?
  estimatedUnitPrice Float?
  estimatedTotal   Float?
  hsnCode          String?
  notes            String?
  status           String              @default("PENDING") // PENDING, APPROVED, REJECTED, PO_RAISED
  isActive         Boolean             @default(true)
  isTestData       Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  createdBy        String?
  updatedBy        String?

  @@map("purchase_requisition_items")
}

// MODULE 24 — RFQ MANAGEMENT
// ============================================================
model Rfq {
  id               String      @id @default(uuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  rfqNumber        String
  prId             String
  pr               PurchaseRequisition @relation(fields: [prId], references: [id])
  title            String
  description      String?
  responseDeadline DateTime
  deliveryLocation String?
  paymentTerms     String?
  status           String      @default("DRAFT") // DRAFT, SENT, CLOSED, CANCELLED
  closedAt         DateTime?
  notes            String?
  isActive         Boolean     @default(true)
  isTestData       Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  createdBy        String?
  updatedBy        String?

  vendors          RfqVendor[]
  items            RfqItem[]
  quotations      VendorQuotation[]
  comparisons     QuotationComparison[]
  purchaseOrders  PurchaseOrder[]

  @@unique([companyId, rfqNumber])
  @@map("rfqs")
}

model RfqVendor {
  id          String   @id @default(uuid())
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id])
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  companyId   String
  status      String   @default("INVITED") // INVITED, QUOTED, DECLINED
  isActive    Boolean  @default(true)
  isTestData  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  @@unique([rfqId, vendorId])
  @@map("rfq_vendors")
}

model RfqItem {
  id          String   @id @default(uuid())
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id])
  prItemId    String?
  companyId   String
  itemCode    String
  itemName    String
  uom         String
  requiredQty Float
  notes       String?
  isActive    Boolean  @default(true)
  isTestData  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  comparisons     QuotationComparison[]

  @@map("rfq_items")
}

// MODULE 25 — VENDOR QUOTATION
// ============================================================
model VendorQuotation {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  quotationNumber  String
  rfqId            String
  rfq              Rfq       @relation(fields: [rfqId], references: [id])
  vendorId         String
  vendor           Vendor    @relation(fields: [vendorId], references: [id])
  validUntil       DateTime
  deliveryDays     Int       @default(30)
  paymentTerms     String?
  currency         String    @default("INR")
  totalAmount      Float?
  status           String    @default("DRAFT") // DRAFT, SUBMITTED, FINALIZED, REJECTED
  notes            String?
  isActive         Boolean   @default(true)
  isTestData       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?
  updatedBy        String?

  items            VendorQuotationItem[]

  comparisons     QuotationComparison[]

  @@unique([companyId, quotationNumber])
  @@unique([rfqId, vendorId])
  @@map("vendor_quotations")
}

model VendorQuotationItem {
  id             String          @id @default(uuid())
  quotationId    String
  quotation      VendorQuotation @relation(fields: [quotationId], references: [id])
  rfqItemId      String?
  companyId      String
  itemCode       String
  itemName       String
  uom            String
  requiredQty    Float
  quotedQty      Float
  unitPrice      Float
  discount       Float?          @default(0)
  taxRate        Float?          @default(0)
  totalPrice     Float
  deliveryDays   Int?
  notes          String?
  isActive       Boolean         @default(true)
  isTestData     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
