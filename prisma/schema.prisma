  issueNumber   String
  workOrderId   String
  workOrder     WorkOrder            @relation(fields: [workOrderId], references: [id])
  warehouseId   String
  warehouse     Warehouse            @relation(fields: [warehouseId], references: [id])
  issueMethod   String               @default("FIFO") // FIFO, FEFO
  status        String               @default("DRAFT") // DRAFT, ISSUED, CANCELLED
  remarks       String?
  isActive      Boolean              @default(true)
  isTestData    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  createdBy     String?
  updatedBy     String?

  items         ProductionIssueItem[]

  @@unique([companyId, issueNumber])
  @@map("production_issues")
}

model ProductionIssueItem {
  id                  String          @id @default(uuid())
  companyId           String
  productionIssueId   String
  productionIssue     ProductionIssue @relation(fields: [productionIssueId], references: [id])
  batchId             String?
  batch               StockBatch?     @relation("ProductionIssueBatch", fields: [batchId], references: [id])
  itemCode            String
  itemName            String
  uom                 String
  requiredQty         Float           @default(0)
  issuedQty           Float           @default(0)
  unitCost            Float           @default(0)
  isActive            Boolean         @default(true)
  isTestData          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  createdBy           String?
  updatedBy           String?

  @@map("production_issue_items")
}

// MODULE 57 — PRODUCTION RECORDING & OUTPUT
// ============================================================
model ProductionEntry {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  entryNumber   String
  workOrderId   String
  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id])
  entryDate     DateTime  @default(now())
  shift         String    @default("MORNING") // MORNING, EVENING, NIGHT
  operatorName  String?
  machineName   String?
  goodQty       Float     @default(0)
  scrapQty      Float     @default(0)
  totalQty      Float     @default(0)
  remarks       String?
  status        String    @default("DRAFT") // DRAFT, CONFIRMED
  isActive      Boolean   @default(true)
  isTestData    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?
  updatedBy     String?

  qcInspections ProductionQc[]
  @@unique([companyId, entryNumber])
  @@index([companyId, workOrderId])
  @@map("production_entries")
}

// MODULE 58 — IN-PROCESS QUALITY CONTROL (IPQC)
// ============================================================
model ProductionQc {
  id                  String          @id @default(uuid())
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id])
  qcNumber            String
  workOrderId         String
  workOrder           WorkOrder       @relation(fields: [workOrderId], references: [id])
  productionEntryId   String?
  productionEntry     ProductionEntry? @relation(fields: [productionEntryId], references: [id])
  inspectionStage     String          @default("IN_PROCESS") // IN_PROCESS, FINAL, INLINE
  inspectorName       String?
  inspectionDate      DateTime        @default(now())
  sampleSize          Int             @default(0)
  passQty             Int             @default(0)
  failQty             Int             @default(0)
  result              String          @default("PENDING") // PASS, FAIL, CONDITIONAL, PENDING
  defectDescription   String?
  correctiveAction    String?
  status              String          @default("PENDING") // PENDING, COMPLETED
  remarks             String?
  isActive            Boolean         @default(true)
  isTestData          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  createdBy           String?
  updatedBy           String?

  @@unique([companyId, qcNumber])
  @@index([companyId, workOrderId])
  @@map("production_qc")
}

// MODULE 59 — FINISHED GOODS RECEIPT
// ============================================================
model FgReceipt {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  receiptNumber String
  workOrderId   String
  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id])
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  itemCode      String
  itemName      String
  uom           String    @default("PCS")
  plannedQty    Float     @default(0)
  receivedQty   Float     @default(0)
  rejectedQty   Float     @default(0)
  batchNumber   String?
  unitCost      Float     @default(0)
  totalCost     Float     @default(0)
  status        String    @default("DRAFT") // DRAFT, RECEIVED
  remarks       String?
  isActive      Boolean   @default(true)
  isTestData    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?
  updatedBy     String?

  oqcInspections OqcInspection[]
  @@unique([companyId, receiptNumber])
  @@index([companyId, workOrderId])
  @@map("fg_receipts")
}

// MODULE 60 — PRODUCTION COST SHEET
// ============================================================
model ProductionCostSheet {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  costSheetNumber   String
  workOrderId       String    @unique
  workOrder         WorkOrder @relation(fields: [workOrderId], references: [id])
  // Material Cost (auto from production issues)
  materialCost      Float     @default(0)
  // Labor Cost (from production entries)
  totalShifts       Int       @default(0)
  laborHours        Float     @default(0)
  laborRatePerHour  Float     @default(0)
  laborCost         Float     @default(0)
  // Overhead (manual)
  overheadCost      Float     @default(0)
  overheadRemarks   String?
  // Other
  otherCost         Float     @default(0)
  otherRemarks      String?
  // Totals
  totalCost         Float     @default(0)
  completedQty      Float     @default(0)
  unitCost          Float     @default(0)
  // Variance
  plannedMaterialCost Float   @default(0)
  varianceCost      Float     @default(0)
  status            String    @default("DRAFT") // DRAFT, FINALIZED
  remarks           String?
  isActive          Boolean   @default(true)
  isTestData        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?

  @@unique([companyId, costSheetNumber])
  @@map("production_cost_sheets")
}

// PHASE 8 — QUALITY MANAGEMENT SYSTEM
// MODULE 63 — NCR & CAPA MANAGEMENT
// ============================================================
model NcrRecord {
  id                    String    @id @default(uuid())
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id])
  ncrNumber             String
  source                String    @default("INTERNAL") // IQC, IPQC, OQC, CUSTOMER_COMPLAINT, INTERNAL_AUDIT, SUPPLIER
  sourceReferenceId     String?
  sourceReferenceNumber String?
  itemCode              String?
  itemName              String?
  workOrderId           String?
  workOrder             WorkOrder? @relation(fields: [workOrderId], references: [id])
  description           String
  severity              String    @default("MINOR") // MINOR, MAJOR, CRITICAL
  qtyAffected           Float     @default(0)
  detectedBy            String?
  detectedDate          DateTime  @default(now())
  disposition           String?   // USE_AS_IS, REWORK, SCRAP, RETURN_TO_VENDOR
  status                String    @default("OPEN") // OPEN, ROOT_CAUSE_PENDING, CAPA_PENDING, VERIFICATION_PENDING, CLOSED
  closedDate            DateTime?
  closedBy              String?
  remarks               String?
  isActive              Boolean   @default(true)
  isTestData            Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             String?
  updatedBy             String?

  capaRecords           CapaRecord[]
  rcaRecords RcaRecord[]
  supplierCars SupplierCar[]

  @@unique([companyId, ncrNumber])
  @@index([companyId, status])
  @@map("ncr_records")
}

model CapaRecord {
  id                  String    @id @default(uuid())
  companyId           String
  company             Company   @relation(fields: [companyId], references: [id])
  capaNumber          String
  ncrId               String
  ncr                 NcrRecord @relation(fields: [ncrId], references: [id])
  rootCause           String?
  correctiveAction    String
  preventiveAction    String?
  assignedTo          String?
  dueDate             DateTime
  completedDate       DateTime?
  effectivenessCheck  String?
  verifiedBy          String?
  verifiedDate        DateTime?
  status              String    @default("ASSIGNED") // ASSIGNED, IN_PROGRESS, COMPLETED, VERIFIED
  remarks             String?
  isActive            Boolean   @default(true)
  isTestData          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdBy           String?
  updatedBy           String?

  @@unique([companyId, capaNumber])
  @@index([companyId, status])
  @@map("capa_records")
}

// MODULE 64 — ROOT CAUSE ANALYSIS
// ============================================================
model RcaRecord {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  rcaNumber     String
  ncrId         String
  ncr           NcrRecord @relation(fields: [ncrId], references: [id])
  method        String    @default("FIVE_WHY") // FIVE_WHY, FISHBONE, BOTH
  problem       String
  // 5-Why fields
  why1          String?
  why2          String?
  why3          String?
  why4          String?
  why5          String?
  rootCause     String?
  // Fishbone fields (stored as JSON)
  fishboneMan         String?
  fishboneMachine     String?
  fishboneMaterial    String?
  fishboneMethod      String?
  fishboneEnvironment String?
  fishboneMeasurement String?
  // Conclusion
  conclusion    String?
  conductedBy   String?
  conductedDate DateTime  @default(now())
  status        String    @default("DRAFT") // DRAFT, COMPLETED
  remarks       String?
  isActive      Boolean   @default(true)
  isTestData    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?
  updatedBy     String?

  @@unique([companyId, rcaNumber])
  @@index([companyId, ncrId])
  @@map("rca_records")
}

// MODULE 65 — OUTGOING QUALITY CONTROL (OQC)
// ============================================================
model OqcInspection {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  oqcNumber       String
  fgReceiptId     String?
  fgReceipt       FgReceipt? @relation(fields: [fgReceiptId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id])
  itemCode        String
  itemName        String
  uom             String    @default("PCS")
  customerName    String?
  lotNumber       String?
  batchNumber     String?
  inspectionDate  DateTime  @default(now())
  inspectorName   String?
  sampleSize      Int       @default(0)
  passQty         Int       @default(0)
  failQty         Int       @default(0)
  // Inspection parameters
  visualCheck     String?   // PASS/FAIL/NA
  dimensionalCheck String?  // PASS/FAIL/NA
  functionalCheck String?   // PASS/FAIL/NA
  packagingCheck  String?   // PASS/FAIL/NA
  labellingCheck  String?   // PASS/FAIL/NA
  // Result
  result          String    @default("PENDING") // PASS, FAIL, CONDITIONAL, PENDING
