  minStockLevel   Float?
  maxStockLevel   Float?
  reorderQty      Float?
  leadTimeDays    Int?
  isActive        Boolean       @default(true)
  isTestData      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  updatedBy       String?

  bomItems        BomItem[]
  prItems         PurchaseRequisitionItem[]

  @@unique([companyId, code])
  @@map("raw_materials")
}

// MODULE 17 — HSN/SAC MASTER
// ============================================================
model HsnSacCode {
