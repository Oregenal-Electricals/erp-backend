# ── Application ──────────────────────────────────────────────────────
APP_NAME=Oregenal ERP
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=oregenal-electrical-india-2024-super-secret-jwt-key-do-not-share
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sidarthakumar@localhost/erp_db
DATABASE_URL_SYNC=postgresql://sidarthakumar@localhost/erp_db

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── AWS S3 (for file uploads) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=oregenal-files-dev

# ── Email (AWS SES) ───────────────────────────────────────────────────
EMAIL_FROM=noreply@oregenal.com
EMAIL_FROM_NAME=Oregenal ERP

# ── First Superadmin (used in seed script) ────────────────────────────
SUPERADMIN_EMAIL=admin@oregenal.com
SUPERADMIN_PASSWORD=Oregenal@2024
SUPERADMIN_NAME=Super Admin

# ── Default Demo Tenant ───────────────────────────────────────────────
DEMO_TENANT_NAME=Oregenal Electrical India Private Limited
DEMO_TENANT_SLUG=oregenal
